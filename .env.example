# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id
# Optional: service-role key bypasses RLS (not required for demo)
# SUPABASE_SERVICE_ROLE_KEY=...

# Codex / OpenAI engine
# Native OpenAI path. OPENAI_API_KEY is accepted as an alias.
CODEX_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
CODEX_MODEL=gpt-4.1-mini

# Optional OpenAI-compatible runtime fallback for demos without a native key.
# CODEX_RUNTIME_KEY=...

# Cloud cost connectors
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GCP_BILLING_BQ_TABLE=project.dataset.table

# Voice gateway
# GATEWAY_URL=https://your-gateway.example.com
# GATEWAY_API_KEY=...

# Gmail outbound email
# GMAIL_USER=you@example.com
# GMAIL_APP_PASSWORD=...

# Plaid Sandbox (optional; enables real bank data)
# PLAID_CLIENT_ID=...
# PLAID_SECRET=...

# Other connectors (optional; all have deterministic fixtures)
# STRIPE_API_KEY=sk_test_...
# SALESFORCE_TOKEN=...
# QUICKBOOKS_TOKEN=...
# GMAIL_TOKEN=...
# OUTLOOK_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# TEAMS_TOKEN=...
# RAZORPAY_KEY_ID=rzp_test_...
# TALLY_TOKEN=...
# ZOHO_TOKEN=...

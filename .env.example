# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id
# Optional: service-role key bypasses RLS (not required for demo)
# SUPABASE_SERVICE_ROLE_KEY=...

# ── Codex — the single AI engine ─────────────────────────────────────────────
# Native OpenAI Codex. Set this to run on api.openai.com.
CODEX_API_KEY=sk-...
CODEX_MODEL=gpt-4.1-mini

# Codex runtime credential — keeps the Codex engine live until a native OpenAI
# key is provided. Used as the OpenAI-compatible transport behind "Codex".
CODEX_RUNTIME_KEY=AIza...

# ── Plaid Sandbox (optional — enables real bank data) ────────────────────────
# PLAID_CLIENT_ID=...
# PLAID_SECRET=...

# ── Cloud FinOps (optional — real data, server-side only, never VITE_) ────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# GCP_SERVICE_ACCOUNT_JSON=...
# GCP_BILLING_BQ_TABLE=project.dataset.table

# ── Gmail (optional — real RFC-822 SMTP send, server-side only) ───────────────
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=...

# ── Other connectors (optional — all have deterministic fixtures) ─────────────
# STRIPE_API_KEY=sk_test_...
# SALESFORCE_TOKEN=...
# QUICKBOOKS_TOKEN=...
# RAZORPAY_KEY_ID=rzp_test_...

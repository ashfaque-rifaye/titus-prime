# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_SUPABASE_PROJECT_ID=your-project-id
# Optional: service-role key bypasses RLS (not required for demo)
# SUPABASE_SERVICE_ROLE_KEY=...

# ── LLM Engines ──────────────────────────────────────────────────────────────
# Gemini 2.5 Flash — primary engine (Google AI Studio key)
GEMINI_API_KEY=AIza...
VITE_GEMINI_API_KEY=AIza...

# Groq — fallback engine (llama-3.3-70b-versatile)
GROQ_API_KEY=gsk_...
VITE_GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI Codex — tertiary engine (activates when key is present)
# CODEX_API_KEY=sk-...
# CODEX_MODEL=gpt-4.1-mini

# ── Plaid Sandbox (optional — enables real bank data) ────────────────────────
# PLAID_CLIENT_ID=...
# PLAID_SECRET=...

# ── Other connectors (optional — all have deterministic fixtures) ─────────────
# STRIPE_API_KEY=sk_test_...
# SALESFORCE_TOKEN=...
# QUICKBOOKS_TOKEN=...
# GMAIL_TOKEN=...
# OUTLOOK_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# TEAMS_TOKEN=...
# RAZORPAY_KEY_ID=rzp_test_...
# TALLY_TOKEN=...
# ZOHO_TOKEN=...
